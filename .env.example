# Application
APP_ENV=development
APP_PORT=8080

# Logging
LOG_LEVEL=debug

# ── Database: Main ────────────────────────────────────────────────────────────
DB_MAIN_DSN=postgres://postgres:secret@localhost:5432/main_db?sslmode=disable

# ── Database: Audit ───────────────────────────────────────────────────────────
DB_AUDIT_DSN=postgres://postgres:secret@localhost:5432/audit_db?sslmode=disable

# ── Connection Pool (shared settings) ─────────────────────────────────────────
DB_MAX_CONNS=25
DB_MIN_CONNS=5
DB_MAX_CONN_LIFETIME=30m
DB_MAX_CONN_IDLE_TIME=15m
DB_HEALTH_CHECK_PERIOD=1m
